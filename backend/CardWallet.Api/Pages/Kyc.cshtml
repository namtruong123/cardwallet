@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Xác Minh Danh Tính (KYC)";
}

<div class="mb-6">
    <h2 class="text-2xl font-bold text-white">Xác Minh Cấp 2 (KYC)</h2>
    <p class="text-slate-400 text-sm mt-1">Nâng cấp tài khoản để mở khóa giới hạn rút điểm và nhận ưu đãi affiliate.</p>
</div>

<div class="bg-cardbg rounded-2xl border border-borderbg p-6 sm:p-8 max-w-3xl">
    <!-- Progress Bar (Static Placeholder) -->
    <div class="flex items-center mb-10">
        <div class="w-8 h-8 rounded-full bg-cyan-500 text-white flex items-center justify-center font-bold text-sm">1</div>
        <div class="flex-1 h-1 mx-2 bg-borderbg relative"><div class="absolute top-0 left-0 h-full bg-cyan-500 w-1/2"></div></div>
        <div class="w-8 h-8 rounded-full bg-darkbg border-2 border-cyan-500 text-cyan-500 flex items-center justify-center font-bold text-sm">2</div>
        <div class="flex-1 h-1 mx-2 bg-borderbg"></div>
        <div class="w-8 h-8 rounded-full bg-darkbg border-2 border-slate-700 text-slate-500 flex items-center justify-center font-bold text-sm">3</div>
    </div>

    <form class="space-y-6 opacity-70 pointer-events-none" title="Chức năng KYC đang được cập nhật">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2">Ảnh CCCD Mặt Trước</label>
                <div class="w-full h-40 border-2 border-dashed border-borderbg rounded-xl bg-darkbg flex flex-col items-center justify-center text-slate-500 hover:border-cyan-500 hover:text-cyan-400 transition-colors cursor-pointer">
                    <i class="fas fa-id-card text-3xl mb-2"></i>
                    <span class="text-xs font-medium">Click để tải lên</span>
                </div>
            </div>
            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2">Ảnh CCCD Mặt Sau</label>
                <div class="w-full h-40 border-2 border-dashed border-borderbg rounded-xl bg-darkbg flex flex-col items-center justify-center text-slate-500 hover:border-cyan-500 hover:text-cyan-400 transition-colors cursor-pointer">
                    <i class="fas fa-id-card text-3xl mb-2"></i>
                    <span class="text-xs font-medium">Click để tải lên</span>
                </div>
            </div>
        </div>
        <div>
            <label class="block text-sm font-bold text-slate-400 mb-2">Ảnh Selfie Chân Dung</label>
            <div class="w-full h-40 border-2 border-dashed border-borderbg rounded-xl bg-darkbg flex flex-col items-center justify-center text-slate-500 hover:border-cyan-500 hover:text-cyan-400 transition-colors cursor-pointer">
                <i class="fas fa-user-circle text-3xl mb-2"></i>
                <span class="text-xs font-medium">Selfie cầm CCCD</span>
            </div>
        </div>
        
        <div class="pt-4 border-t border-borderbg">
            <button type="button" class="bg-cyan-600 text-white font-bold py-3 px-8 rounded-xl opacity-50 cursor-not-allowed">Gửi Yêu Cầu Duyệt</button>
            <span class="ml-4 text-xs text-amber-400"><i class="fas fa-hammer mr-1"></i> Tính năng sắp ra mắt</span>
        </div>
    </form>
</div>
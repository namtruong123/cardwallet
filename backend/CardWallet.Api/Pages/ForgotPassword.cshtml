@page
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Khôi Phục Mật Khẩu - CardWallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>tailwind.config={darkMode:'class',theme:{extend:{colors:{darkbg:'#080C16',cardbg:'#111827',borderbg:'#1E293B'}}}}</script>
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-darkbg min-h-screen flex items-center justify-center relative overflow-hidden text-slate-300">
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden z-0 pointer-events-none">
        <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-pink-600/20 rounded-full blur-[120px]"></div>
    </div>

    <div class="relative bg-cardbg/80 backdrop-blur-xl border border-borderbg rounded-3xl shadow-2xl p-8 sm:p-10 w-full max-w-md z-10 m-4">
        <div class="text-center mb-8">
            <a href="/"><div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-pink-500 to-rose-600 text-white mb-4 shadow-lg shadow-pink-500/30"><i class="fas fa-lock"></i></div></a>
            <h1 class="text-2xl font-bold text-white mb-1">Khôi Phục Mật Khẩu</h1>
            <p class="text-slate-400 text-sm">Nhập email để nhận liên kết đặt lại mật khẩu</p>
        </div>
        <form class="space-y-5" onsubmit="event.preventDefault(); alert('Tính năng gửi email đang được phát triển!'); window.location.href='/Account/Login';">
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1.5">Địa chỉ Email</label>
                <input type="email" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:ring-2 focus:ring-pink-500 outline-none transition-all text-slate-200" placeholder="account@example.com" />
            </div>
            <button type="submit" class="w-full bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-500 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg shadow-pink-500/20 mt-2">
                Gửi Yêu Cầu
            </button>
        </form>
        <p class="mt-8 text-center text-sm text-slate-400"><a href="/Account/Login" class="text-pink-400 font-bold hover:underline">&larr; Quay lại đăng nhập</a></p>
    </div>
</body>
</html>
@page
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Đăng nhập";
}

<section class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
        <div class="mb-8 text-center">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-cyan-300">CardWallet</p>
            <h1 class="mt-3 text-3xl font-bold text-white">Đăng nhập</h1>
            <p class="mt-3 text-sm text-slate-400">Sử dụng email hoặc số điện thoại để truy cập hệ thống.</p>
        </div>

        <form id="user-login-form" method="post" action="/login" class="rounded-2xl border border-borderbg bg-cardbg p-6 shadow-2xl space-y-5">
            <div>
                <label for="login" class="block text-sm font-semibold text-slate-300 mb-2">Email hoặc số điện thoại</label>
                <input id="login" name="login" type="text" autocomplete="username" required
                       class="w-full rounded-xl border border-borderbg bg-darkbg px-4 py-3 text-white outline-none focus:border-cyan-400 transition-colors"
                       placeholder="email@gmail.com hoặc 0901234567" />
            </div>

            <div>
                <label for="password" class="block text-sm font-semibold text-slate-300 mb-2">Mật khẩu</label>
                <input id="password" name="password" type="password" autocomplete="current-password" required
                       class="w-full rounded-xl border border-borderbg bg-darkbg px-4 py-3 text-white outline-none focus:border-cyan-400 transition-colors"
                       placeholder="Mật khẩu" />
            </div>

            <button type="submit" class="w-full rounded-xl bg-cyan-500 py-3 font-bold text-slate-900 hover:bg-cyan-400 transition-colors">
                Đăng nhập
            </button>

            <div class="flex items-center justify-between text-sm">
                <a href="/ForgotPassword" class="text-slate-400 hover:text-cyan-300">Quên mật khẩu?</a>
                <a href="/Register" class="font-semibold text-cyan-300 hover:text-cyan-200">Tạo tài khoản mới</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="~/assets/js/user-dashboard.js" asp-append-version="true"></script>
}

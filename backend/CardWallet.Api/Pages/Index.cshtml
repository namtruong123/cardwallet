@page
@model CardWallet.Api.Pages.IndexModel
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Trang Chủ - Đổi Thẻ Cào Uy Tín";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        .defi-body { font-family: 'DM Sans', 'Plus Jakarta Sans', sans-serif; }

        /* Floating green dots animation */
        .floating-dot {
            position: absolute;
            width: 6px;
            height: 6px;
            background: #4ADE80;
            border-radius: 50%;
            opacity: 0.5;
            animation: floatDot 8s ease-in-out infinite;
        }
        .floating-dot:nth-child(2) { animation-delay: -2s; animation-duration: 10s; }
        .floating-dot:nth-child(3) { animation-delay: -4s; animation-duration: 12s; }
        .floating-dot:nth-child(4) { animation-delay: -1s; animation-duration: 9s; }
        .floating-dot:nth-child(5) { animation-delay: -3s; animation-duration: 11s; }
        .floating-dot:nth-child(6) { animation-delay: -5s; animation-duration: 7s; }
        .floating-dot:nth-child(7) { animation-delay: -6s; animation-duration: 13s; }
        .floating-dot:nth-child(8) { animation-delay: -7s; animation-duration: 10s; }

        @@keyframes floatDot {
            0%, 100% { transform: translateY(0px) translateX(0px); opacity: 0.4; }
            25% { transform: translateY(-20px) translateX(10px); opacity: 0.7; }
            50% { transform: translateY(-10px) translateX(-15px); opacity: 0.3; }
            75% { transform: translateY(-25px) translateX(5px); opacity: 0.6; }
        }

        /* Green ambient glow */
        .green-glow {
            background: radial-gradient(ellipse at top right, rgba(74, 222, 128, 0.12) 0%, transparent 60%);
        }

        /* Feature card hover */
        .feature-card {
            transition: all 0.3s ease;
        }
        .feature-card:hover {
            border-color: rgba(74, 222, 128, 0.25);
            transform: translateY(-2px);
        }

        /* Step card with tilt */
        .step-card-left {
            transform: rotate(-3deg);
            transition: transform 0.4s ease;
        }
        .step-card-left:hover { transform: rotate(0deg); }
        .step-card-right {
            transform: rotate(3deg);
            transition: transform 0.4s ease;
        }
        .step-card-right:hover { transform: rotate(0deg); }

        /* Mint diagonal stripes for How it Works background */
        .mint-stripes {
            background-image:
                linear-gradient(135deg, rgba(74, 222, 128, 0.08) 25%, transparent 25%),
                linear-gradient(225deg, rgba(74, 222, 128, 0.08) 25%, transparent 25%);
            background-size: 200px 200px;
        }

        /* Smooth scroll */
        html { scroll-behavior: smooth; }
    </style>
}


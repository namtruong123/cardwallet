    <script>
        (function () {
            const activeClasses = ['border-emerald-400/60', 'bg-emerald-400/10', 'text-emerald-300', 'opacity-100', 'shadow-lg', 'shadow-emerald-500/10'];
            const inactiveClasses = ['border-transparent', 'text-gray-400', 'opacity-45', 'grayscale'];
            const useHardcodedRates = true;
            const testFaceValues = [10000, 20000, 30000, 50000, 100000, 200000, 300000, 500000, 1000000];
            const testProviderDiscounts = {
                Viettel: 20,
                Mobifone: 22,
                Vinaphone: 21,
                Vietnamobile: 18,
                Garena: 15
            };
            const testRates = Object.entries(testProviderDiscounts).flatMap(([provider, discountPercent]) =>
                testFaceValues.map(faceValue => ({
                    provider,
                    faceValue,
                    discountPercent,
                    receiveAmount: Math.round(faceValue * (100 - discountPercent) / 100)
                }))
            );
            const state = {
                rates: [],
                provider: 'Viettel'
            };

            function formatMoney(value) {
                return new Intl.NumberFormat('vi-VN').format(Number(value || 0));
            }

            function escapeHtml(value) {
                return String(value ?? '').replace(/[&<>"']/g, char => ({
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#39;'
                })[char]);
            }

            function normalizeProvider(value) {
                return String(value || '').trim().toLowerCase();
            }

            function setActiveProvider(provider) {
                state.provider = provider;

                document.querySelectorAll('.public-provider-filter').forEach(button => {
                    const isActive = button.dataset.provider === provider;

                    button.setAttribute('aria-pressed', String(isActive));
                    button.classList.toggle('grayscale', !isActive);
                    button.classList.remove(...(isActive ? inactiveClasses : activeClasses));
                    button.classList.add(...(isActive ? activeClasses : inactiveClasses));
                });
            }

            function renderRates() {
                const body = document.getElementById('public-rates-body');
                if (!body) return;

                const providerRates = state.rates.filter(rate => normalizeProvider(rate.provider) === normalizeProvider(state.provider));

                if (providerRates.length === 0) {
                    body.innerHTML = `
                        <tr>
                            <td colspan="3" class="px-6 py-8 text-center text-gray-500">Ch&#432;a c&#243; b&#7843;ng gi&#225; cho ${escapeHtml(state.provider)}.</td>
                        </tr>
                    `;
                    return;
                }

                body.innerHTML = providerRates.map(rate => `
                    <tr class="hover:bg-gray-800/30 transition-colors">
                        <td class="px-6 py-4 text-right text-gray-300">${formatMoney(rate.faceValue)} VND</td>
                        <td class="px-6 py-4 text-right text-emerald-400 font-bold">${formatMoney(rate.discountPercent)}%</td>
                        <td class="px-6 py-4 text-right text-cyan-400 font-bold">${formatMoney(rate.receiveAmount)} xu</td>
                    </tr>
                `).join('');
            }

            async function loadRates() {
                const body = document.getElementById('public-rates-body');
                if (!body) return;

                body.innerHTML = '<tr><td colspan="3" class="px-6 py-8 text-center text-gray-500">&#272;ang t&#7843;i b&#7843;ng gi&#225;...</td></tr>';

                if (useHardcodedRates) {
                    state.rates = testRates;
                    setActiveProvider(state.provider);
                    renderRates();
                    return;
                }

                try {
                    const response = await fetch('/api/card-rates');
                    if (!response.ok) throw new Error('Cannot load rates');

                    const rates = await response.json();
                    state.rates = Array.isArray(rates) && rates.length > 0 ? rates : testRates;

                    if (state.rates.length === 0) {
                        body.innerHTML = '<tr><td colspan="3" class="px-6 py-8 text-center text-gray-500">Ch&#432;a c&#243; b&#7843;ng gi&#225; &#273;ang ho&#7841;t &#273;&#7897;ng.</td></tr>';
                        return;
                    }

                    const hasDefaultProvider = state.rates.some(rate => normalizeProvider(rate.provider) === normalizeProvider(state.provider));
                    if (!hasDefaultProvider) {
                        state.provider = state.rates[0].provider || state.provider;
                    }

                    setActiveProvider(state.provider);
                    renderRates();
                } catch {
                    state.rates = testRates;
                    setActiveProvider(state.provider);
                    renderRates();
                }
            }

            function initProviderRates() {
                document.querySelectorAll('.public-provider-filter').forEach(button => {
                    button.addEventListener('click', () => {
                        setActiveProvider(button.dataset.provider);
                        renderRates();
                    });
                });

                setActiveProvider(state.provider);
                loadRates();
            }

            document.addEventListener('DOMContentLoaded', function () {
                setTimeout(initProviderRates, 0);
            });
        })();
    </script>


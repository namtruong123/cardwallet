@page
@model CardWallet.Api.Pages.Admin.SsoModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác thực quản trị - CardWallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['"Plus Jakarta Sans"', 'sans-serif'] },
                    colors: { darkbg: '#020617', cardbg: '#0f172a', borderbg: '#1e293b' }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-darkbg text-slate-300 flex items-center justify-center min-h-screen selection:bg-cyan-500/30">
    <div class="w-full max-w-md p-6">
        <div class="bg-cardbg rounded-2xl border border-borderbg p-8 shadow-2xl text-center space-y-6">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-br from-cyan-500 to-blue-600 shadow-lg shadow-cyan-500/20">
                <i class="fas fa-shield-halved text-white text-2xl animate-pulse"></i>
            </div>
            
            <div class="space-y-2">
                <h1 class="text-xl font-bold text-white tracking-tight">Xác thực hệ thống</h1>
                <p class="text-slate-400 text-sm">Vui lòng chờ trong giây lát để hệ thống đồng bộ phiên đăng nhập...</p>
            </div>
            
            <div class="flex justify-center py-4">
                <div class="relative w-12 h-12">
                    <div class="absolute inset-0 border-4 border-slate-700/50 rounded-full"></div>
                    <div class="absolute inset-0 border-4 border-cyan-500 border-t-transparent rounded-full animate-spin"></div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const params = new URLSearchParams(window.location.search);
            const token = params.get("token");
            const refreshToken = params.get("refreshToken");
            const userId = params.get("userId");
            const fullName = params.get("fullName");
            const email = params.get("email");
            const phoneNumber = params.get("phoneNumber");
            const role = params.get("role") || "Admin";

            if (token) {
                const secure = window.location.protocol === "https:" ? "; Secure" : "";
                document.cookie = `adminAccessToken=${encodeURIComponent(token)}; Path=/; SameSite=Lax${secure}`;
                localStorage.setItem("adminToken", token);
                localStorage.setItem("adminUser", JSON.stringify({
                    userId: userId,
                    fullName: fullName,
                    email: email,
                    phoneNumber: phoneNumber,
                    role: role
                }));
                // Short timeout to let the user feel the smooth transition, then redirect to root dashboard
                setTimeout(() => {
                    window.location.href = "/";
                }, 800);
            } else {
                // Fallback to the main domain login page
                const host = window.location.host;
                let loginUrl = "";
                if (host.includes("localhost") || host.includes("127.0.0.1") || host.includes("lvh.me")) {
                    loginUrl = window.location.protocol + "//lvh.me:" + window.location.port + "/login";
                } else {
                    loginUrl = window.location.protocol + "//mmohub.xyz/login";
                }
                window.location.href = loginUrl;
            }
        });
    </script>
</body>
</html>

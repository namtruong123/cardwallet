@page
@{
    Layout = "_ModernAdminLayout";
    ViewData["Title"] = "Hoa hồng";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-white tracking-tight">Cấu hình hoa hồng</h1>
    <p class="text-slate-400 text-sm mt-1">Tính % hoa hồng từ doanh thu CTV mang lại cho quản lý/đối tác/tổ chức.</p>
</div>

<section class="bg-cardbg border border-borderbg rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b border-borderbg">
        <h2 class="font-semibold text-white">Rank hoa hồng đề xuất</h2>
        <p class="text-xs text-slate-500 mt-1">Admin cần có module chỉnh sửa % theo rank.</p>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full text-left whitespace-nowrap">
            <thead class="bg-darkbg text-xs uppercase tracking-wider text-slate-400">
                <tr>
                    <th class="px-5 py-3">Rank</th>
                    <th class="px-5 py-3">Điều kiện</th>
                    <th class="px-5 py-3 text-right">% hoa hồng</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-borderbg text-sm">
                <tr><td class="px-5 py-3 text-white">Mặc định</td><td class="px-5 py-3 text-slate-400">Hơn 5 CTV dưới link REF</td><td class="px-5 py-3 text-right text-cyan-300">2%</td></tr>
                <tr><td class="px-5 py-3 text-white">Hạng Bạc</td><td class="px-5 py-3 text-slate-400">Hơn 10 CTV dưới link REF</td><td class="px-5 py-3 text-right text-cyan-300">3%</td></tr>
                <tr><td class="px-5 py-3 text-white">Hạng Vàng</td><td class="px-5 py-3 text-slate-400">Hơn 50 CTV dưới link REF</td><td class="px-5 py-3 text-right text-cyan-300">5%</td></tr>
                <tr><td class="px-5 py-3 text-white">Hạng Kim cương</td><td class="px-5 py-3 text-slate-400">Hơn 100 CTV dưới link REF</td><td class="px-5 py-3 text-right text-cyan-300">10%</td></tr>
            </tbody>
        </table>
    </div>
</section>

<section class="mt-6 bg-cardbg border border-borderbg rounded-xl p-5">
    <h2 class="font-semibold text-white">API cần phát triển</h2>
    <p class="text-sm text-slate-500 mt-2">Cần thêm CommissionPolicy, ReferralCommission, job tính hoa hồng và màn duyệt/đối soát payout.</p>
</section>

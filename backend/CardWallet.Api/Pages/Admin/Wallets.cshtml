@page
@{
    Layout = "_ModernAdminLayout";
    ViewData["Title"] = "Quản lý ví điểm";
}

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h1 class="text-2xl font-bold text-white tracking-tight">Quản lý ví điểm</h1>
        <p class="text-slate-400 text-sm mt-1">Theo dõi dòng tiền điểm. Admin chuyển điểm thì ví admin giảm, ví người nhận tăng, tổng cung không đổi.</p>
    </div>
    <button onclick="openWalletModal()" class="bg-gradient-to-r from-amber-600 to-orange-600 hover:from-amber-500 hover:to-orange-500 text-white font-medium py-2 px-4 rounded-lg transition-all flex items-center shadow-lg shadow-amber-500/20">
        <i class="fas fa-right-left mr-2"></i> Chuyển điểm
    </button>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
    <div class="bg-cardbg rounded-xl border border-borderbg p-4">
        <p class="text-xs uppercase tracking-wider text-slate-500">Tổng cung</p>
        <p class="mt-2 text-2xl font-bold text-white">50.000.000 điểm</p>
    </div>
    <div class="bg-cardbg rounded-xl border border-borderbg p-4">
        <p class="text-xs uppercase tracking-wider text-slate-500">Nguyên tắc chuyển</p>
        <p class="mt-2 text-sm text-slate-300">Không sinh thêm điểm. Chỉ chuyển từ ví admin sang ví nhận.</p>
    </div>
    <div class="bg-cardbg rounded-xl border border-borderbg p-4">
        <p class="text-xs uppercase tracking-wider text-slate-500">Cảnh báo</p>
        <p class="mt-2 text-sm text-amber-300">Dữ liệu cũ từng mint sai cần reconcile bằng bút toán riêng.</p>
    </div>
</div>

<div class="bg-cardbg rounded-xl border border-borderbg p-4 mb-6 flex flex-col sm:flex-row gap-4">
    <div class="flex-1 relative">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-500"></i>
        <input type="text" id="wallet-search" placeholder="Tìm theo User ID, Wallet ID, tên người dùng..." class="w-full pl-10 pr-4 py-2 bg-darkbg border border-borderbg rounded-lg focus:outline-none focus:border-cyan-500 text-slate-200">
    </div>
</div>

<div class="bg-cardbg rounded-xl border border-borderbg overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-borderbg text-left whitespace-nowrap">
            <thead class="bg-darkbg text-slate-400 text-xs uppercase tracking-wider">
                <tr>
                    <th class="px-6 py-4 font-medium">Thành viên</th>
                    <th class="px-6 py-4 font-medium text-right">Tổng điểm</th>
                    <th class="px-6 py-4 font-medium text-right">Điểm đang khóa</th>
                    <th class="px-6 py-4 font-medium text-right">Điểm khả dụng</th>
                    <th class="px-6 py-4 font-medium text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="wallets-table-body" class="divide-y divide-borderbg text-sm">
                <tr><td colspan="5" class="px-6 py-8 text-center text-slate-500"><i class="fas fa-spinner fa-spin mr-2"></i> Đang tải dữ liệu...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div id="wallet-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
    <div class="bg-cardbg border border-borderbg rounded-2xl w-full max-w-md shadow-2xl relative">
        <div class="p-5 border-b border-borderbg flex justify-between items-center">
            <h3 class="text-lg font-bold text-white"><i class="fas fa-right-left text-amber-500 mr-2"></i> Chuyển điểm từ ví admin</h3>
            <button onclick="document.getElementById('wallet-modal').classList.add('hidden')" class="text-slate-400 hover:text-white transition-colors"><i class="fas fa-times text-xl"></i></button>
        </div>
        <div class="p-5">
            <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-3 mb-4">
                <p class="text-xs text-amber-400"><i class="fas fa-exclamation-triangle mr-1"></i> Đây là chuyển điểm, không phải tạo điểm mới. Ví admin sẽ bị trừ đúng số điểm chuyển.</p>
            </div>
            <form id="wallet-adjust-form" class="space-y-4">
                <div id="wallet-message" class="text-sm font-medium p-2 rounded hidden"></div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">User ID người nhận</label>
                    <input type="text" name="userId" required class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg focus:outline-none focus:border-cyan-500 text-slate-200 font-mono text-sm" placeholder="Nhập User ID người nhận" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Số điểm chuyển</label>
                    <input type="number" name="amount" min="1" required class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg focus:outline-none focus:border-cyan-500 text-slate-200" placeholder="VD: 1000" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Lý do chuyển</label>
                    <textarea name="reason" rows="2" required class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg focus:outline-none focus:border-cyan-500 text-slate-200 resize-none" placeholder="VD: Chuyển điểm cho user sau đối soát..."></textarea>
                </div>
                <div class="pt-2 flex gap-3">
                    <button type="submit" class="flex-1 bg-gradient-to-r from-amber-600 to-orange-600 hover:from-amber-500 hover:to-orange-500 text-white font-medium py-2 rounded-lg transition-all shadow-lg shadow-amber-500/20">Chuyển điểm</button>
                    <button type="button" onclick="document.getElementById('wallet-modal').classList.add('hidden')" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 font-medium py-2 rounded-lg transition-colors">Hủy</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openWalletModal(userId = '') {
        document.getElementById('wallet-modal').classList.remove('hidden');
        const form = document.getElementById('wallet-adjust-form');
        if (form) {
            form.reset();
            if (userId) form.querySelector('[name="userId"]').value = userId;
        }
    }
</script>

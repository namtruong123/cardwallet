@page
@{
    Layout = "_ModernAdminLayout";
    ViewData["Title"] = "Cài đặt hệ thống";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-white tracking-tight">Cài đặt hệ thống</h1>
    <p class="text-slate-400 text-sm mt-1">Cấu hình API trang mẹ, đơn vị tiền tệ và chuẩn thời gian hiển thị.</p>
</div>

<section class="bg-cardbg border border-borderbg rounded-xl p-5">
    <form id="admin-settings-form" class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        <div>
            <label class="block text-xs font-medium text-slate-400 mb-1">API trang mẹ</label>
            <input name="ParentApi__BaseUrl" class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg text-slate-200 text-sm focus:outline-none focus:border-cyan-500" placeholder="https://api.trangme.com" />
        </div>
        <div>
            <label class="block text-xs font-medium text-slate-400 mb-1">API key trang mẹ</label>
            <input name="ParentApi__ApiKey" class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg text-slate-200 text-sm focus:outline-none focus:border-cyan-500" placeholder="Nhập API key" />
        </div>
        <div>
            <label class="block text-xs font-medium text-slate-400 mb-1">Tỷ lệ VND / 1 xu</label>
            <input name="Money__VndPerPoint" type="number" min="1" class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg text-slate-200 text-sm focus:outline-none focus:border-cyan-500" placeholder="1000" />
        </div>
        <div>
            <label class="block text-xs font-medium text-slate-400 mb-1">Timezone hiển thị</label>
            <input name="System__DisplayTimezone" class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg text-slate-200 text-sm focus:outline-none focus:border-cyan-500" placeholder="Asia/Bangkok" />
        </div>
        <div class="lg:col-span-2 flex justify-end">
            <button type="submit" class="px-5 py-2 rounded-lg bg-gradient-to-r from-cyan-600 to-blue-600 text-white text-sm font-medium shadow-lg shadow-cyan-500/20">
                <i class="fas fa-save mr-2"></i> Lưu cấu hình
            </button>
        </div>
    </form>
</section>

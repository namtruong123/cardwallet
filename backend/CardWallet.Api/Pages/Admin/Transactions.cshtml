@page
@{
    Layout = "_ModernAdminLayout";
    ViewData["Title"] = "Đối soát giao dịch";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-white tracking-tight">Đối soát giao dịch</h1>
    <p class="text-slate-400 text-sm mt-1">Tra cứu biến động số dư, giao dịch thẻ cào và trạng thái xử lý.</p>
</div>

<div class="bg-cardbg rounded-xl border border-borderbg p-5 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 items-end">
        <div>
            <label class="block text-sm font-medium text-slate-400 mb-1.5">User ID / Mã giao dịch</label>
            <input id="transaction-search" type="text" class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg focus:outline-none focus:border-cyan-500 text-slate-200 text-sm" placeholder="Nhập ID..." />
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-400 mb-1.5">Trạng thái</label>
            <select id="transaction-status" class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg focus:outline-none focus:border-cyan-500 text-slate-200 text-sm">
                <option value="all">Tất cả</option>
                <option value="Completed">Thành công (Completed)</option>
                <option value="Success">Thành công (Success)</option>
                <option value="Failed">Thất bại (Failed)</option>
                <option value="Pending">Chờ xử lý (Pending)</option>
                <option value="Processing">Đang xử lý (Processing)</option>
            </select>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-400 mb-1.5">Phân loại</label>
            <select id="transaction-type" class="w-full px-3 py-2 bg-darkbg border border-borderbg rounded-lg focus:outline-none focus:border-cyan-500 text-slate-200 text-sm">
                <option value="all">Tất cả</option>
                <option value="Deposit">Nạp xu</option>
                <option value="Withdraw">Rút xu</option>
                <option value="Deposit_Card">Nạp thẻ cào</option>
            </select>
        </div>
        <div>
            <button id="transaction-filter" type="button" class="w-full bg-slate-800 hover:bg-slate-700 text-white font-medium py-2 px-4 rounded-lg transition-colors flex items-center justify-center border border-borderbg">
                <i class="fas fa-filter mr-2"></i> Lọc dữ liệu
            </button>
        </div>
    </div>
</div>

<div class="bg-cardbg rounded-xl border border-borderbg overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-borderbg text-left whitespace-nowrap">
            <thead class="bg-darkbg text-slate-400 text-xs uppercase tracking-wider">
                <tr>
                    <th class="px-5 py-4 font-medium">Mã GD</th>
                    <th class="px-5 py-4 font-medium">Khách hàng</th>
                    <th class="px-5 py-4 font-medium">Loại GD</th>
                    <th class="px-5 py-4 font-medium text-right">Số xu</th>
                    <th class="px-5 py-4 font-medium text-center">Trạng thái</th>
                    <th class="px-5 py-4 font-medium text-right">Thời gian</th>
                </tr>
            </thead>
            <tbody id="transactions-table-body" class="divide-y divide-borderbg text-sm">
                <tr><td colspan="6" class="px-5 py-8 text-center text-slate-500"><i class="fas fa-spinner fa-spin mr-2"></i> Đang tải dữ liệu...</td></tr>
            </tbody>
        </table>
    </div>
</div>

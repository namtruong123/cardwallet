@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Xác Minh Danh Tính (KYC)";
}

<div class="mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Xác Minh Danh Tính (KYC Cấp 2)</h2>
            <p class="text-slate-400 text-sm mt-1">Cung cấp thông tin để mở khóa tính năng rút xu và bảo mật tài khoản.</p>
        </div>
        <div>
            <button type="button" id="btn-show-qr" class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-200 hover:text-white rounded-xl text-sm font-semibold border border-borderbg transition-colors">
                <i class="fas fa-qrcode"></i>
                Quét mã QR trên điện thoại
            </button>
        </div>
    </div>
</div>

<!-- Status Banner -->
<div id="kyc-status-banner" class="hidden mb-6 rounded-2xl border p-4 sm:p-5 flex items-start gap-4">
    <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg shrink-0" id="kyc-status-icon"></div>
    <div class="flex-1">
        <h4 class="font-bold text-white text-base" id="kyc-status-title">Trạng thái KYC</h4>
        <p class="text-sm text-slate-400 mt-1" id="kyc-status-desc"></p>
    </div>
</div>

<!-- Main Form Container -->
<div id="kyc-form-container" class="bg-cardbg rounded-2xl border border-borderbg p-6 sm:p-8 max-w-3xl">
    <form id="kyc-submit-form" class="space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Mặt trước CCCD -->
            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2">Ảnh CCCD / CMND Mặt Trước <span class="text-rose-500">*</span></label>
                <div class="relative group">
                    <input type="file" id="front-file" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                    <div id="front-preview" class="w-full h-48 border-2 border-dashed border-borderbg group-hover:border-cyan-500/50 rounded-xl bg-darkbg flex flex-col items-center justify-center text-slate-500 group-hover:text-slate-300 transition-all overflow-hidden p-2">
                        <i class="fas fa-id-card text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="text-xs font-semibold text-center">Bấm để chọn file hoặc chụp hình mặt trước</span>
                        <span class="text-[10px] text-slate-600 mt-1">Định dạng JPG, PNG, WEBP tối đa 5MB</span>
                    </div>
                </div>
            </div>

            <!-- Mặt sau CCCD -->
            <div>
                <label class="block text-sm font-bold text-slate-400 mb-2">Ảnh CCCD / CMND Mặt Sau <span class="text-rose-500">*</span></label>
                <div class="relative group">
                    <input type="file" id="back-file" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                    <div id="back-preview" class="w-full h-48 border-2 border-dashed border-borderbg group-hover:border-cyan-500/50 rounded-xl bg-darkbg flex flex-col items-center justify-center text-slate-500 group-hover:text-slate-300 transition-all overflow-hidden p-2">
                        <i class="fas fa-id-card text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="text-xs font-semibold text-center">Bấm để chọn file hoặc chụp hình mặt sau</span>
                        <span class="text-[10px] text-slate-600 mt-1">Định dạng JPG, PNG, WEBP tối đa 5MB</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ảnh khuôn mặt (Selfie) -->
        <div>
            <label class="block text-sm font-bold text-slate-400 mb-2">Hình Chụp Khuôn Mặt <span class="text-rose-500">*</span></label>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5 items-stretch">
                <!-- Selfie Preview/Upload -->
                <div class="md:col-span-2 relative group min-h-48">
                    <input type="file" id="selfie-file" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                    <div id="selfie-preview" class="w-full h-full border-2 border-dashed border-borderbg group-hover:border-cyan-500/50 rounded-xl bg-darkbg flex flex-col items-center justify-center text-slate-500 group-hover:text-slate-300 transition-all overflow-hidden p-3 min-h-48">
                        <i class="fas fa-user-astronaut text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="text-xs font-semibold text-center">Bấm để chọn file hoặc chụp chân dung</span>
                        <span class="text-[10px] text-slate-600 mt-1">Tải file có sẵn từ thiết bị</span>
                    </div>
                </div>

                <!-- Camera Control card -->
                <div class="bg-darkbg border border-borderbg rounded-xl p-5 flex flex-col items-center justify-center text-center">
                    <div class="w-12 h-12 rounded-full bg-cyan-500/10 text-cyan-400 flex items-center justify-center text-xl mb-3">
                        <i class="fas fa-camera"></i>
                    </div>
                    <h5 class="text-white font-bold text-sm mb-1">Chụp bằng điện thoại / máy tính</h5>
                    <p class="text-xs text-slate-500 mb-4">Sử dụng webcam trực tiếp để chụp ảnh chân dung chất lượng.</p>
                    <button type="button" id="btn-open-camera" class="w-full py-2 px-3 bg-cyan-600 hover:bg-cyan-500 text-white text-xs font-bold rounded-lg transition-colors">
                        Mở camera trực tiếp
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Submit Button -->
        <div class="pt-6 border-t border-borderbg flex items-center justify-between gap-4">
            <button type="submit" id="btn-kyc-submit" class="bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-lg shadow-cyan-600/10">
                Gửi Yêu Cầu Xác Minh
            </button>
            <span class="text-xs text-slate-500 flex items-center"><i class="fas fa-shield-halved mr-1.5 text-cyan-500"></i> Dữ liệu của bạn được mã hóa an toàn</span>
        </div>
    </form>
</div>

<!-- QR Code Modal -->
<div id="qr-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center bg-black/70 backdrop-blur-sm p-4">
    <div class="bg-cardbg border border-borderbg rounded-2xl max-w-sm w-full p-6 text-center relative shadow-2xl">
        <button type="button" class="absolute top-4 right-4 text-slate-400 hover:text-white" onclick="document.getElementById('qr-modal').classList.add('hidden')">
            <i class="fas fa-times text-lg"></i>
        </button>
        <h3 class="text-white font-bold text-lg mb-2">Xác Thực Trên Điện Thoại</h3>
        <p class="text-slate-400 text-xs mb-5">Mở camera trên điện thoại hoặc quét mã QR dưới đây để truy cập trang xác minh trực tiếp, giúp việc chụp hình CCCD và selfie dễ dàng hơn.</p>
        
        <div class="bg-white p-3 rounded-xl inline-block mx-auto mb-4">
            <img id="qr-img" src="" alt="Mã QR KYC" class="w-48 h-48">
        </div>
        
        <div class="text-[10px] font-mono text-cyan-400 select-all p-2 bg-darkbg rounded-lg border border-borderbg truncate" id="qr-link">
            ...
        </div>
    </div>
</div>

<!-- Camera Capture Modal -->
<div id="camera-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
    <div class="bg-cardbg border border-borderbg rounded-2xl max-w-lg w-full overflow-hidden relative shadow-2xl flex flex-col max-h-[90vh]">
        <div class="px-5 py-4 border-b border-borderbg flex items-center justify-between">
            <h3 class="text-white font-bold">Chụp Ảnh Khuôn Mặt Trực Tiếp</h3>
            <button type="button" id="btn-close-camera" class="text-slate-400 hover:text-white">
                <i class="fas fa-times text-lg"></i>
            </button>
        </div>
        
        <div class="flex-1 bg-black relative flex items-center justify-center overflow-hidden min-h-[300px]">
            <!-- Camera Video Feed -->
            <video id="camera-video" autoplay playsinline class="w-full h-full object-cover"></video>
            
            <!-- Face Guideline Mask Overlay -->
            <div class="absolute inset-0 border-[30px] border-black/60 pointer-events-none flex items-center justify-center">
                <div class="w-64 h-64 border-2 border-cyan-500 border-dashed rounded-full shadow-[0_0_0_9999px_rgba(0,0,0,0.4)]"></div>
            </div>
            
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 bg-black/60 backdrop-blur text-white text-[10px] px-3 py-1 rounded-full border border-white/10 pointer-events-none">
                Đặt khuôn mặt trong vòng tròn xanh
            </div>
        </div>
        
        <div class="p-5 border-t border-borderbg bg-darkbg flex justify-center gap-4">
            <button type="button" id="btn-capture-snap" class="px-6 py-3 bg-cyan-600 hover:bg-cyan-500 text-white font-bold rounded-xl transition-all flex items-center gap-2">
                <i class="fas fa-circle-dot text-rose-500 animate-pulse"></i>
                Bấm Chụp Ảnh
            </button>
        </div>
    </div>
</div>

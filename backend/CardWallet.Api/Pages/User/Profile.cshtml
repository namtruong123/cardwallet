@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Ho so";
}

<div class="mb-6">
    <h2 class="text-2xl font-bold text-white">Ho so nguoi dung</h2>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <section class="bg-cardbg rounded-2xl border border-borderbg p-6">
        <div class="flex items-center gap-4 mb-6">
            <img id="prof-avatar" src="https://ui-avatars.com/api/?name=User&background=0f172a&color=06b6d4" class="w-20 h-20 rounded-2xl border-2 border-cyan-500/50" alt="Avatar">
            <div>
                <h3 class="text-xl font-bold text-white" id="prof-name">...</h3>
                <p class="text-sm text-slate-400">UID: <span class="font-mono text-xs" id="prof-id">...</span></p>
            </div>
        </div>
        <div class="space-y-4 border-t border-borderbg pt-6">
            <div><p class="text-xs text-slate-500 font-bold uppercase mb-1">Ho ten</p><p class="text-white font-medium" id="field-name">...</p></div>
            <div><p class="text-xs text-slate-500 font-bold uppercase mb-1">Email</p><div class="flex justify-between gap-3"><p class="text-white font-medium break-all" id="field-email">...</p><span id="badge-email"></span></div></div>
            <div><p class="text-xs text-slate-500 font-bold uppercase mb-1">So dien thoai</p><div class="flex justify-between gap-3"><p class="text-white font-medium" id="field-phone">...</p><span id="badge-phone"></span></div></div>
        </div>
    </section>
    <section class="bg-cardbg rounded-2xl border border-borderbg p-6">
        <h3 class="font-bold text-white mb-4">Trang thai tai khoan</h3>
        <div id="prof-status" class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-xs font-bold">
            Active
        </div>
    </section>
</div>

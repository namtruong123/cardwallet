@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Bảng giá";
}

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h2 class="text-2xl font-bold text-white">Bảng giá chiết khấu thẻ</h2>
        <p class="text-slate-400 text-sm mt-1">Dữ liệu lấy từ API card-rates hiện có.</p>
    </div>
    <input id="rate-search" type="text" placeholder="Tìm nhà mạng" class="w-full sm:w-64 px-4 py-3 bg-cardbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-sm" />
</div>

<section class="bg-cardbg rounded-2xl border border-borderbg overflow-hidden shadow-lg">
    <div class="overflow-x-auto">
        <table class="min-w-full text-left whitespace-nowrap">
            <thead class="bg-darkbg text-slate-400 text-xs uppercase tracking-wider border-b border-borderbg">
                <tr>
                    <th class="px-6 py-4 font-bold">Nhà mạng</th>
                    <th class="px-6 py-4 font-bold text-right">Mệnh giá</th>
                    <th class="px-6 py-4 font-bold text-right">Chiết khấu</th>
                    <th class="px-6 py-4 font-bold text-right text-cyan-400">Nhận được</th>
                </tr>
            </thead>
            <tbody id="rates-body" class="divide-y divide-borderbg/50 text-sm">
                <tr><td colspan="4" class="p-8 text-center text-slate-500">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</section>

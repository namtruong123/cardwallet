@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Doi the cao";
}

<div class="mb-6">
    <h2 class="text-2xl font-bold text-white">Gui the cao len he thong</h2>
    <p class="text-slate-400 text-sm mt-1">Chon dung nha mang va menh gia de tinh so xu nhan duoc.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <section class="bg-cardbg rounded-2xl border border-borderbg p-6 sm:p-8">
        <form id="exchange-form" class="space-y-5">
            <div class="bg-amber-500/10 border border-amber-500/20 rounded-xl p-3.5 flex items-start gap-3">
                <i class="fas fa-exclamation-triangle text-amber-500 mt-0.5"></i>
                <p class="text-xs text-amber-400 leading-relaxed font-medium">Vui long chon dung menh gia. Chon sai menh gia co the lam giao dich that bai.</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nha mang</label>
                    <select id="ex-provider" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-sm"></select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Menh gia</label>
                    <select id="ex-facevalue" required disabled class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-sm disabled:opacity-50"></select>
                </div>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Serial</label>
                <input id="ex-serial" type="text" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 font-mono" />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Ma the</label>
                <input id="ex-code" type="text" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 font-mono" />
            </div>
            <div class="p-4 bg-darkbg border border-borderbg rounded-xl flex justify-between items-center">
                <p class="text-xs text-slate-500 font-medium">Chiet khau: <span id="ex-discount" class="text-white font-bold">0%</span></p>
                <div class="text-right">
                    <p class="text-xs text-slate-500 font-medium">Nhan duoc</p>
                    <p class="text-xl font-bold text-cyan-400" id="ex-receive">0 XU</p>
                </div>
            </div>
            <button id="ex-submit-btn" type="submit" class="w-full bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-cyan-500/20">
                <i class="fas fa-paper-plane mr-2"></i>Gui the
            </button>
        </form>
    </section>
    <aside id="exchange-result" class="hidden"></aside>
</div>

@page
@model CardWallet.Api.Pages.User.ReferralsModel
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Liên kết giới thiệu";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-white tracking-tight">Liên kết giới thiệu</h1>
    <p class="text-slate-400 text-sm mt-1">Quản lý mã giới thiệu (mã REF), xem danh sách thành viên giới thiệu và gửi yêu cầu chuyển nhóm Ref.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Links & Request Transfer Form -->
    <div class="lg:col-span-1 space-y-6">
        <!-- Referral Link Card -->
        <div class="bg-cardbg border border-borderbg rounded-2xl p-6 shadow-xl space-y-4">
            <h3 class="text-white font-bold text-base flex items-center gap-2">
                <i class="fas fa-link text-cyan-400"></i> Link giới thiệu (Mã REF)
            </h3>
            <p class="text-xs text-slate-400">Chia sẻ liên kết này để mời thành viên tham gia hệ thống và nhận hoa hồng chiết khấu.</p>
            
            <div class="space-y-3">
                <div class="relative">
                    <input id="ref-link" type="text" readonly class="w-full rounded-xl border border-borderbg bg-darkbg pl-4 pr-12 py-3 text-white outline-none text-xs font-mono" />
                    <button onclick="copyRefLink()" class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-white p-2">
                        <i class="far fa-copy text-sm"></i>
                    </button>
                </div>
                <div class="flex justify-between items-center text-xs text-slate-400">
                    <span>Mã Ref: <span id="ref-code" class="font-mono text-cyan-400 font-bold">...</span></span>
                </div>
            </div>
        </div>

        <!-- Request Transfer Referrer Form -->
        <div class="bg-cardbg border border-borderbg rounded-2xl p-6 shadow-xl space-y-4">
            <h3 class="text-white font-bold text-base flex items-center gap-2">
                <i class="fas fa-right-left text-cyan-400"></i> Đơn xin chuyển nhóm Ref
            </h3>
            <p class="text-xs text-slate-400">Gửi yêu cầu thay đổi sang người giới thiệu hoặc Đối tác/Tổ chức quản lý khác.</p>
            
            <form id="ref-transfer-form" class="space-y-4">
                <div>
                    <label for="new-referrer" class="block text-xs font-semibold text-slate-300 mb-2">ID Quản lý / Đối tác mới</label>
                    <input id="new-referrer" type="text" required placeholder="Nhập ID người quản lý mới..." class="w-full rounded-xl border border-borderbg bg-darkbg px-4 py-3 text-white outline-none focus:border-cyan-400 text-sm font-mono" />
                </div>
                <div>
                    <label for="transfer-reason" class="block text-xs font-semibold text-slate-300 mb-2">Lý do chuyển</label>
                    <textarea id="transfer-reason" rows="2" placeholder="Nhập lý do..." class="w-full rounded-xl border border-borderbg bg-darkbg px-4 py-3 text-white outline-none focus:border-cyan-400 text-sm"></textarea>
                </div>
                <button type="submit" class="w-full rounded-xl bg-cyan-500 py-3 font-bold text-slate-900 hover:bg-cyan-400 transition-colors text-sm">
                    Gửi yêu cầu chuyển Ref
                </button>
            </form>
        </div>
    </div>

    <!-- Referral List Table -->
    <div class="lg:col-span-2">
        <div class="bg-cardbg border border-borderbg rounded-2xl overflow-hidden shadow-xl">
            <div class="px-6 py-4 border-b border-borderbg">
                <h3 class="text-white font-bold text-base">Cộng tác viên trực thuộc của bạn</h3>
            </div>
            
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-borderbg text-left whitespace-nowrap">
                    <thead class="bg-darkbg text-slate-400 text-xs uppercase tracking-wider">
                        <tr>
                            <th class="px-6 py-3 font-medium">Thành viên</th>
                            <th class="px-6 py-3 font-medium">Số điện thoại</th>
                            <th class="px-6 py-3 font-medium text-right">Tổng giao dịch</th>
                            <th class="px-6 py-3 font-medium text-right">Hoa hồng nhận</th>
                        </tr>
                    </thead>
                    <tbody id="ref-table-body" class="divide-y divide-borderbg text-sm">
                        <tr>
                            <td colspan="4" class="px-6 py-8 text-center text-slate-500">Chưa có thành viên trực thuộc nào đăng ký qua mã của bạn.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const refLinkInput = document.getElementById('ref-link');
            const refCodeEl = document.getElementById('ref-code');

            // Get current user token and ID
            const raw = localStorage.getItem('authData');
            let token = "";
            if (raw) {
                try { token = JSON.parse(raw).accessToken; } catch(e) {}
            }

            if (token) {
                // Fetch profile to get user ID
                fetch('/api/users/me', {
                    headers: { 'Authorization': `Bearer ${token}` }
                })
                .then(res => res.json())
                .then(user => {
                    if (user && user.id) {
                        const shortId = user.id.slice(0, 8);
                        refCodeEl.textContent = shortId.toUpperCase();
                        
                        const domain = window.location.origin;
                        refLinkInput.value = `${domain}/register?ref=${user.id}`;
                    }
                })
                .catch(err => {
                    console.error("Lỗi lấy thông tin Ref:", err);
                });
            }

            window.copyRefLink = function() {
                if (!refLinkInput.value) return;
                refLinkInput.select();
                refLinkInput.setSelectionRange(0, 99999); // For mobile devices
                navigator.clipboard.writeText(refLinkInput.value)
                    .then(() => {
                        alert("Đã sao chép liên kết giới thiệu!");
                    })
                    .catch(() => {
                        alert("Không thể sao chép liên kết.");
                    });
            };

            document.getElementById('ref-transfer-form')?.addEventListener('submit', (e) => {
                e.preventDefault();
                const newRef = document.getElementById('new-referrer').value.trim();
                alert(`Gửi yêu cầu chuyển sang nhóm Ref quản lý ${newRef} thành công! Đang chờ Admin duyệt.`);
                document.getElementById('ref-transfer-form').reset();
            });
        });
    </script>
}

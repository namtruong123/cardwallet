@page
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng Ký - CardWallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700&display=swap" rel="stylesheet" />
    <script>tailwind.config={darkMode:'class',theme:{extend:{colors:{darkbg:'#0B0F19',cardbg:'#151C2C',borderbg:'#252D40'}}}}</script>
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-darkbg min-h-screen flex items-center justify-center relative overflow-x-hidden text-slate-300 py-10">
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden z-0">
        <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-cyan-600/20 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-violet-600/20 rounded-full blur-[120px]"></div>
    </div>

    <div class="relative bg-cardbg/80 backdrop-blur-xl border border-borderbg rounded-[24px] shadow-2xl p-8 sm:p-10 w-full max-w-lg z-10 m-4">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-white mb-2">Tạo Tài Khoản Mới</h1>
            <p class="text-slate-400 text-sm">Tham gia nền tảng trao đổi thẻ cào uy tín nhất</p>
        </div>
        <form id="user-register-form" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1.5">Họ và Tên</label>
                <input type="text" name="fullName" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all text-slate-200" placeholder="VD: Nguyen Van A" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1.5">Số điện thoại</label>
                    <input type="text" name="phoneNumber" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all text-slate-200" placeholder="09..." />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1.5">Email</label>
                    <input type="email" name="email" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all text-slate-200" placeholder="email@@..." />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1.5">Mật khẩu</label>
                <input type="password" name="password" required minlength="6" class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 outline-none transition-all text-slate-200" placeholder="••••••••" />
            </div>
            <div class="bg-blue-500/10 border border-blue-500/20 rounded-xl p-3 mt-2 flex items-start gap-3">
                <i class="fas fa-info-circle text-blue-400 mt-0.5"></i>
                <p class="text-xs text-blue-300/80">Bạn sẽ cần xác thực Số điện thoại và Email sau khi đăng ký để sử dụng đầy đủ các tính năng nạp/rút tiền.</p>
            </div>
            <button type="submit" class="w-full bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg shadow-cyan-500/20 mt-4">
                Đăng Ký Tài Khoản
            </button>
        </form>
        <p class="mt-8 text-center text-sm text-slate-400">Đã có tài khoản? <a href="/Account/Login" class="text-cyan-400 font-medium hover:text-cyan-300 transition-colors">Đăng nhập</a></p>
    </div>
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2"></div>
    <script src="/assets/js/user-dashboard.js"></script>
</body>
</html>
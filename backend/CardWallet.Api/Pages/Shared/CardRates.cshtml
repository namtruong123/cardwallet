@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Bảng Giá Chiết Khấu";
}

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h2 class="text-2xl font-bold text-white">Bảng Giá Thẻ Cào</h2>
        <p class="text-slate-400 text-sm mt-1">Tỉ lệ chiết khấu được hệ thống tự động cập nhật theo thời gian thực.</p>
    </div>
    <a href="/user/exchange" class="bg-gradient-to-r from-amber-500 to-orange-500 text-white font-bold py-2 px-5 rounded-xl shadow-lg shadow-orange-500/20 hover:scale-105 transition-transform"><i class="fas fa-bolt mr-1"></i> Đổi Thẻ Ngay</a>
</div>

<div class="bg-cardbg rounded-[20px] border border-borderbg overflow-hidden shadow-lg">
    <div class="overflow-x-auto">
        <table class="min-w-full text-left whitespace-nowrap">
            <thead class="bg-darkbg text-slate-400 text-xs uppercase tracking-wider border-b border-borderbg">
                <tr>
                    <th class="px-6 py-4 font-bold">Nhà Mạng</th>
                    <th class="px-6 py-4 font-bold text-right">Mệnh Giá Thẻ</th>
                    <th class="px-6 py-4 font-bold text-right">Chiết Khấu</th>
                    <th class="px-6 py-4 font-bold text-right text-cyan-400">Bạn Nhận Được (XU)</th>
                </tr>
            </thead>
            <tbody id="rates-body" class="divide-y divide-borderbg/50 text-sm"></tbody>
        </table>
    </div>
</div>
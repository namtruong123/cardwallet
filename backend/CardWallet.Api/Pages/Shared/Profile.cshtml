@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Hồ Sơ Của Tôi";
}

<div class="mb-6"><h2 class="text-2xl font-bold text-white">Hồ Sơ & Xác Thực</h2></div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-cardbg rounded-[20px] border border-borderbg p-6">
        <div class="flex items-center gap-4 mb-6">
            <img src="https://ui-avatars.com/api/?name=User&background=0f172a&color=06b6d4" class="w-20 h-20 rounded-3xl border-2 border-cyan-500/50">
            <div>
                <h3 class="text-xl font-bold text-white" id="prof-name">...</h3>
                <p class="text-sm text-slate-400">UID: <span class="font-mono text-xs" id="prof-id">...</span></p>
            </div>
        </div>
        <div class="space-y-4 border-t border-borderbg pt-6">
            <div>
                <p class="text-xs text-slate-500 font-bold uppercase mb-1">Số điện thoại</p>
                <div class="flex justify-between items-center"><p class="text-white font-medium" id="prof-phone">...</p><span id="badge-phone"></span></div>
            </div>
            <div>
                <p class="text-xs text-slate-500 font-bold uppercase mb-1">Địa chỉ Email</p>
                <div class="flex justify-between items-center"><p class="text-white font-medium" id="prof-email">...</p><span id="badge-email"></span></div>
            </div>
        </div>
    </div>
    <div class="bg-cardbg rounded-[20px] border border-borderbg p-6">
        <h3 class="font-bold text-white mb-4">Xác minh danh tính (KYC)</h3>
        <div class="bg-darkbg border border-borderbg rounded-xl p-5 text-center">
            <div class="w-16 h-16 rounded-full bg-slate-800 flex items-center justify-center text-slate-500 text-2xl mx-auto mb-3"><i class="fas fa-id-card"></i></div>
            <p class="text-white font-bold mb-1">Chưa Xác Minh Cấp 2</p>
            <p class="text-xs text-slate-400 mb-4">Xác minh CCCD/CMND để tăng hạn mức rút tiền và mở khóa Affiliate.</p>
            <button class="bg-slate-800 text-slate-300 hover:text-white font-bold py-2 px-6 rounded-lg text-sm transition-colors border border-borderbg">Bắt Đầu Xác Minh (Sắp ra mắt)</button>
        </div>
    </div>
</div>
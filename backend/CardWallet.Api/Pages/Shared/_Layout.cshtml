@{
    var host = Context.Request.Host.Host.ToLowerInvariant();
    var port = Context.Request.Host.Port.HasValue ? $":{Context.Request.Host.Port}" : "";
    var adminUrl = (host.Contains("localhost") || host.Contains("lvh.me") || host.Equals("127.0.0.1")) ? $"{Context.Request.Scheme}://app.lvh.me{port}" : $"{Context.Request.Scheme}://app.mmohub.xyz";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CardWallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-gray-50 text-gray-800">
    <header class="bg-white/90 backdrop-blur-md shadow-sm sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <a href="/" class="flex-shrink-0 font-bold text-xl flex items-center gap-2">
                    <i class="fas fa-wallet text-cyan-500"></i>
                    <span>CardWallet</span>
                </a>
                <div class="hidden md:flex items-center gap-2">
                    <a href="/cardrates" class="text-gray-600 hover:bg-gray-100 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium">Bảng giá</a>
                    <a href="/guide" class="text-gray-600 hover:bg-gray-100 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium">Hướng dẫn</a>
                    <a href="/user/exchange" class="text-gray-600 hover:bg-gray-100 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium">Đổi thẻ</a>
                    <a href="@adminUrl" class="text-gray-600 hover:bg-gray-100 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium">Quản trị</a>
                </div>
                <div class="hidden md:flex items-center">
                    <a href="/login" class="text-gray-600 hover:text-gray-900 font-medium mr-4">Đăng nhập</a>
                    <a href="/register" class="bg-cyan-500 hover:bg-cyan-600 text-white px-4 py-2 rounded-lg font-semibold shadow-md transition-colors">Đăng ký ngay</a>
                </div>
                <button id="public-menu-button" type="button" class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-lg border border-gray-200 text-gray-700">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
            <div id="public-mobile-menu" class="hidden md:hidden border-t border-gray-100 py-3">
                <div class="flex flex-col gap-1">
                    <a href="/cardrates" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-100">Bảng giá</a>
                    <a href="/guide" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-100">Hướng dẫn</a>
                    <a href="/user/exchange" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-100">Đổi thẻ</a>
                    <a href="@adminUrl" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-100">Quản trị</a>
                    <div class="mt-2 grid grid-cols-2 gap-2">
                        <a href="/login" class="text-center rounded-lg border border-gray-200 px-3 py-2 text-sm font-semibold text-gray-700">Đăng nhập</a>
                        <a href="/register" class="text-center rounded-lg bg-cyan-500 px-3 py-2 text-sm font-semibold text-white">Đăng ký</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-slate-900 text-white">
        <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8 text-center">
            <p>&copy; @DateTime.Now.Year CardWallet Platform. All rights reserved.</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.getElementById('public-menu-button')?.addEventListener('click', function () {
            document.getElementById('public-mobile-menu')?.classList.toggle('hidden');
        });
    </script>
</body>
</html>

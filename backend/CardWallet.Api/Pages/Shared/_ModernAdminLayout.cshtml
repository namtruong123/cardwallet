<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CardWallet Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        (function () {
            if (sessionStorage.getItem('adminSessionActive') !== '1') {
                localStorage.removeItem('adminToken');
                localStorage.removeItem('adminUser');
                document.cookie = 'adminAccessToken=; Path=/; Max-Age=0; SameSite=Lax';
                window.location.replace('/login');
                return;
            }
        })();

        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['"Plus Jakarta Sans"', 'sans-serif'] },
                    colors: { darkbg: '#020617', cardbg: '#0f172a', borderbg: '#1e293b' }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #020617; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #475569; }
    </style>
</head>
<body class="bg-darkbg text-slate-300 flex h-screen overflow-hidden selection:bg-cyan-500/30">
    <div id="admin-mobile-overlay" class="fixed inset-0 z-30 hidden bg-black/60 md:hidden"></div>

    <aside id="admin-sidebar" class="fixed md:static inset-y-0 left-0 z-40 hidden md:flex w-64 bg-cardbg border-r border-borderbg flex-col shadow-xl">
        <div class="h-16 flex items-center px-6 border-b border-borderbg">
            <div class="w-8 h-8 rounded bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center mr-3 shadow-lg shadow-cyan-500/20">
                <i class="fas fa-wallet text-white text-sm"></i>
            </div>
            <h2 class="text-lg font-bold text-white tracking-wide">CardWallet<span class="text-cyan-500">.</span></h2>
        </div>

        <nav id="sidebar-menu" class="flex-1 px-3 py-6 space-y-1 overflow-y-auto">
            <a href="/" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-home w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Dashboard
            </a>
            <a href="/users" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-users w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Người dùng
            </a>
            <a href="/wallets" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-coins w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Ví xu
            </a>
            <a href="/cardrates" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-percent w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Bảng giá
            </a>
            <a href="/transactions" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-exchange-alt w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Giao dịch
            </a>

            <div class="pt-4 pb-2">
                <p class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Hệ thống</p>
            </div>
            <a href="/kyc" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-id-card w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Duyệt KYC
            </a>
            <a href="/withdrawals" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-money-bill-wave w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Rút xu
            </a>
            <a href="/deposits" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-circle-plus w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Nạp xu
            </a>
            <a href="/referrals" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-link w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Link REF
            </a>
            <a href="/commissions" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-percent w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Hoa hồng
            </a>
            <a href="/settings" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-cog w-5 mr-3 text-slate-500 group-hover:text-cyan-400 transition-colors"></i> Cài đặt
            </a>
        </nav>

        <div class="p-4 border-t border-borderbg">
            <button id="admin-logout-btn" class="w-full flex items-center justify-center px-4 py-2.5 bg-slate-800/50 hover:bg-rose-500/10 text-slate-400 hover:text-rose-500 rounded-lg transition-colors text-sm font-medium border border-transparent hover:border-rose-500/20">
                <i class="fas fa-sign-out-alt mr-2"></i> Đăng xuất
            </button>
        </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0 overflow-hidden relative">
        <header class="h-16 bg-cardbg/80 backdrop-blur-md border-b border-borderbg flex items-center justify-between px-4 sm:px-6 z-10">
            <div class="flex min-w-0 items-center">
                <button id="admin-menu-button" type="button" class="md:hidden shrink-0 text-slate-400 hover:text-white mr-4">
                    <i class="fas fa-bars text-xl"></i>
                </button>
                <h1 class="text-base sm:text-lg font-semibold text-white truncate">@ViewData["Title"]</h1>
            </div>
            <div class="flex shrink-0 items-center space-x-3 sm:space-x-4">
                <div class="relative hidden lg:block">
                    <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-sm"></i>
                    <input type="text" placeholder="Tìm kiếm nhanh..." class="bg-darkbg border border-borderbg rounded-full pl-9 pr-4 py-1.5 text-sm text-slate-200 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors w-64">
                </div>
                <button class="relative p-2 text-slate-400 hover:text-white transition-colors" type="button">
                    <i class="far fa-bell"></i>
                    <span class="absolute top-1 right-1 w-2 h-2 bg-rose-500 rounded-full border-2 border-cardbg"></span>
                </button>
                <div class="flex items-center border-l border-borderbg pl-3 sm:pl-4">
                    <img id="admin-current-avatar" src="https://ui-avatars.com/api/?name=Admin&background=0D8ABC&color=fff" alt="Admin" class="w-8 h-8 rounded-full border border-slate-700">
                    <div class="ml-2 hidden sm:block leading-tight">
                        <span id="admin-current-name" class="block text-sm font-medium text-slate-200">Admin</span>
                        <span id="admin-current-role" class="block text-[10px] uppercase tracking-wide text-cyan-400">ADMIN</span>
                    </div>
                </div>
            </div>
        </header>

        <main class="flex-1 overflow-x-hidden overflow-y-auto bg-darkbg p-3 sm:p-6 lg:p-8">
            <div class="max-w-7xl mx-auto">
                @RenderBody()
            </div>
        </main>
    </div>

    <div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2"></div>

    <script src="/assets/js/admin.js" asp-append-version="true"></script>
    <script src="/assets/js/i18n.js" asp-append-version="true"></script>
    <script>
        (function () {
            const sidebar = document.getElementById('admin-sidebar');
            const overlay = document.getElementById('admin-mobile-overlay');
            const button = document.getElementById('admin-menu-button');

            function closeMenu() {
                sidebar?.classList.add('hidden');
                sidebar?.classList.remove('flex');
                overlay?.classList.add('hidden');
            }

            function openMenu() {
                sidebar?.classList.remove('hidden');
                sidebar?.classList.add('flex');
                overlay?.classList.remove('hidden');
            }

            button?.addEventListener('click', openMenu);
            overlay?.addEventListener('click', closeMenu);
            sidebar?.querySelectorAll('a[href]').forEach(link => link.addEventListener('click', closeMenu));
            document.getElementById('admin-logout-btn')?.addEventListener('click', () => {
                sessionStorage.removeItem('adminSessionActive');
                localStorage.removeItem('adminToken');
                localStorage.removeItem('adminUser');
                document.cookie = 'adminAccessToken=; Path=/; Max-Age=0; SameSite=Lax';
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

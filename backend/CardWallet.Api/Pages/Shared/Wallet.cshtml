@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Ví Của Tôi";
}

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <h2 class="text-2xl font-bold text-white">Quản Lý Số Dư</h2>
    <div class="flex gap-3">
        <button class="bg-darkbg border border-borderbg text-slate-400 font-bold py-2 px-4 rounded-xl opacity-50 cursor-not-allowed text-sm"><i class="fab fa-cc-visa mr-1"></i> Nạp Tiền</button>
        <button class="bg-gradient-to-r from-violet-600 to-fuchsia-600 text-white font-bold py-2 px-4 rounded-xl shadow-lg shadow-violet-500/20 text-sm hover:scale-105 transition-transform"><i class="fas fa-building-columns mr-1"></i> Rút Tiền (Bank)</button>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
    <div class="bg-gradient-to-br from-cyan-600 to-blue-700 rounded-[20px] p-6 text-white shadow-lg shadow-cyan-500/20">
        <p class="text-cyan-100 text-xs font-bold uppercase tracking-wider mb-2">Số Dư Khả Dụng</p>
        <h3 class="text-3xl font-bold mb-1" id="wallet-avail-xu">0</h3>
        <p class="text-cyan-200 text-sm font-medium" id="wallet-avail-vnd">~ 0 VNĐ</p>
    </div>
    <div class="bg-cardbg rounded-[20px] border border-borderbg p-6">
        <p class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-2">Đang Tạm Giữ</p>
        <h3 class="text-2xl font-bold text-amber-400 mb-1" id="wallet-locked-xu">0</h3>
        <p class="text-slate-500 text-sm font-medium" id="wallet-locked-vnd">~ 0 VNĐ</p>
    </div>
    <div class="bg-cardbg rounded-[20px] border border-borderbg p-6">
        <p class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-2">Tổng Tài Sản</p>
        <h3 class="text-2xl font-bold text-white mb-1" id="wallet-total-xu">0</h3>
        <p class="text-slate-500 text-sm font-medium" id="wallet-total-vnd">~ 0 VNĐ</p>
    </div>
</div>

<div class="bg-cardbg rounded-[20px] border border-borderbg overflow-hidden shadow-lg">
    <div class="px-6 py-5 border-b border-borderbg"><h3 class="font-bold text-white">Biến Động Số Dư (Sổ Cái)</h3></div>
    <div class="overflow-x-auto p-2">
        <table class="min-w-full text-left whitespace-nowrap">
            <thead class="bg-darkbg text-slate-400 text-[11px] uppercase tracking-widest border-b border-borderbg"><tr><th class="px-4 py-4 font-bold">Mã GD</th><th class="px-4 py-4 font-bold">Loại</th><th class="px-4 py-4 font-bold text-right">Số Tiền (XU)</th><th class="px-4 py-4 font-bold">Nội Dung</th><th class="px-4 py-4 font-bold text-right">Thời Gian</th></tr></thead>
            <tbody id="wallet-txs-body" class="divide-y divide-borderbg/50 text-sm"></tbody>
        </table>
    </div>
</div>
@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Đổi Thẻ Cào";
}

<div class="mb-6">
    <h2 class="text-2xl font-bold text-white">Gửi Thẻ Cào Lên Hệ Thống</h2>
    <p class="text-slate-400 text-sm mt-1">Hỗ trợ Viettel, Vinaphone, Mobifone, Zing, Garena. Xử lý tự động 5s - 1p.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div class="bg-cardbg rounded-[20px] border border-borderbg p-6 sm:p-8 relative">
        <div class="absolute top-0 right-0 w-32 h-32 bg-cyan-500/5 rounded-bl-[100px] pointer-events-none"></div>
        <form id="exchange-form" class="space-y-5 relative z-10">
            <div class="bg-amber-500/10 border border-amber-500/20 rounded-xl p-3.5 flex items-start gap-3 mb-6">
                <i class="fas fa-exclamation-triangle text-amber-500 mt-0.5"></i>
                <p class="text-xs text-amber-400 leading-relaxed font-medium">Vui lòng chọn <strong>ĐÚNG MỆNH GIÁ</strong>. Chọn sai mệnh giá thẻ có thể bị phạt hoặc mất thẻ 100%.</p>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Nhà Mạng</label>
                    <select id="ex-provider" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-sm font-medium appearance-none cursor-pointer">
                        <option value="">-- Chọn --</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Mệnh Giá</label>
                    <select id="ex-facevalue" required disabled class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-sm font-medium appearance-none disabled:opacity-50 cursor-pointer">
                        <option value="">-- Chọn Mạng Trước --</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Mã Thẻ (Mã PIN)</label>
                <input type="text" id="ex-code" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-lg font-mono placeholder-slate-600" placeholder="Nhập mã nạp tiền..." />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Số Serial</label>
                <input type="text" id="ex-serial" required class="w-full px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-lg font-mono placeholder-slate-600" placeholder="Nhập số seri in trên thẻ..." />
            </div>
            <div class="p-4 bg-darkbg border border-borderbg rounded-xl flex justify-between items-center">
                <div><p class="text-xs text-slate-500 font-medium">Chiết khấu áp dụng: <span id="ex-discount" class="text-white font-bold">0%</span></p></div>
                <div class="text-right"><p class="text-xs text-slate-500 font-medium">Bạn sẽ nhận:</p><p class="text-xl font-bold text-cyan-400" id="ex-receive">0 XU</p></div>
            </div>
            <button type="submit" id="ex-submit-btn" class="w-full bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-cyan-500/20 flex items-center justify-center gap-2">
                <i class="fas fa-paper-plane"></i> GỬI THẺ LÊN HỆ THỐNG
            </button>
        </form>
    </div>
    <div id="exchange-result" class="hidden"></div>
</div>
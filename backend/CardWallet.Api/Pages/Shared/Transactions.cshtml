@page
@{
    Layout = "_UserDashboardLayout";
    ViewData["Title"] = "Lịch Sử Gửi Thẻ";
}

<div class="mb-6"><h2 class="text-2xl font-bold text-white">Lịch Sử Đổi Thẻ</h2></div>

<div class="bg-cardbg rounded-[20px] border border-borderbg p-5 mb-6 flex flex-col sm:flex-row gap-4">
    <div class="flex-1 relative">
        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-500"></i>
        <input type="text" id="tx-search" placeholder="Tìm mã thẻ, serial..." class="w-full pl-11 pr-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-sm">
    </div>
    <select id="tx-status" class="w-full sm:w-48 px-4 py-3 bg-darkbg border border-borderbg rounded-xl focus:outline-none focus:border-cyan-500 text-slate-200 text-sm">
        <option value="">Tất cả trạng thái</option>
        <option value="Success">Thành công</option>
        <option value="Failed">Thẻ Lỗi</option>
        <option value="Pending">Chờ xử lý</option>
    </select>
</div>

<div class="bg-cardbg rounded-[20px] border border-borderbg overflow-hidden shadow-lg">
    <div class="overflow-x-auto p-2">
        <table class="min-w-full text-left whitespace-nowrap">
            <tbody id="card-txs-body" class="divide-y divide-borderbg/50 text-sm"></tbody>
        </table>
    </div>
</div>
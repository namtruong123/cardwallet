@page
@model CardWallet.Api.Pages.Partnership.IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đối tác & Tổ chức - CardWallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['"Plus Jakarta Sans"', 'sans-serif'] },
                    colors: { darkbg: '#020617', cardbg: '#0f172a', borderbg: '#1e293b' }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-darkbg text-slate-300 flex h-screen overflow-hidden selection:bg-teal-500/30">
    <!-- Mobile Overlay -->
    <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/60 md:hidden"></div>

    <!-- Sidebar -->
    <aside id="partner-sidebar" class="fixed md:static inset-y-0 left-0 z-40 hidden md:flex w-64 bg-cardbg border-r border-borderbg flex-col shadow-xl">
        <div class="h-16 flex items-center px-6 border-b border-borderbg">
            <div class="w-8 h-8 rounded bg-gradient-to-br from-teal-500 to-emerald-600 flex items-center justify-center mr-3 shadow-lg shadow-teal-500/20">
                <i class="fas fa-handshake text-white text-sm"></i>
            </div>
            <h2 class="text-lg font-bold text-white tracking-wide">Partner<span class="text-teal-400">Hub</span></h2>
        </div>

        <nav class="flex-1 px-3 py-6 space-y-1 overflow-y-auto">
            <a href="#" class="flex items-center px-3 py-2.5 text-sm font-semibold text-teal-400 bg-slate-800/80 rounded-lg group">
                <i class="fas fa-home w-5 mr-3 text-teal-400"></i> Dashboard
            </a>
            <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-link w-5 mr-3 text-slate-500 group-hover:text-teal-400 transition-colors"></i> Quản lý mã REF
            </a>
            <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-users-viewfinder w-5 mr-3 text-slate-500 group-hover:text-teal-400 transition-colors"></i> Thành viên tổ chức
            </a>
            <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-wallet w-5 mr-3 text-slate-500 group-hover:text-teal-400 transition-colors"></i> Ví & Hoa hồng
            </a>
            <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium text-slate-400 hover:text-slate-100 hover:bg-slate-800/50 rounded-lg transition-colors group">
                <i class="fas fa-envelope-open-text w-5 mr-3 text-slate-500 group-hover:text-teal-400 transition-colors"></i> Bài viết truyền thông
            </a>
        </nav>

        <div class="p-4 border-t border-borderbg">
            <button id="logout-btn" class="w-full flex items-center justify-center px-4 py-2.5 bg-slate-800/50 hover:bg-rose-500/10 text-slate-400 hover:text-rose-500 rounded-lg transition-colors text-sm font-medium border border-transparent hover:border-rose-500/20">
                <i class="fas fa-sign-out-alt mr-2"></i> Đăng xuất
            </button>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden relative">
        <header class="h-16 bg-cardbg/80 backdrop-blur-md border-b border-borderbg flex items-center justify-between px-4 sm:px-6 z-10">
            <div class="flex min-w-0 items-center">
                <button id="menu-button" type="button" class="md:hidden shrink-0 text-slate-400 hover:text-white mr-4">
                    <i class="fas fa-bars text-xl"></i>
                </button>
                <h1 class="text-base sm:text-lg font-semibold text-white truncate">Tổng quan Đối tác</h1>
            </div>
            
            <div class="flex shrink-0 items-center space-x-3 sm:space-x-4">
                <div class="flex items-center border-l border-borderbg pl-3 sm:pl-4">
                    <img id="user-avatar" src="https://ui-avatars.com/api/?name=Partner&background=0D8ABC&color=fff" alt="Partner" class="w-8 h-8 rounded-full border border-slate-700">
                    <div class="ml-2 hidden sm:block leading-tight text-left">
                        <span id="partner-name" class="block text-sm font-medium text-slate-200">Đối tác</span>
                        <span class="block text-[10px] uppercase tracking-wide text-teal-400">Partner & Org</span>
                    </div>
                </div>
            </div>
        </header>

        <main class="flex-1 overflow-x-hidden overflow-y-auto bg-darkbg p-3 sm:p-6 lg:p-8">
            <div class="max-w-7xl mx-auto space-y-6">
                <!-- Welcome Section -->
                <div class="bg-gradient-to-r from-teal-900/40 via-emerald-900/20 to-transparent rounded-2xl border border-teal-500/20 p-6 shadow-xl">
                    <h2 class="text-xl font-bold text-white tracking-tight">Chào mừng Đối tác liên kết, <span id="welcome-name" class="text-teal-400">Tổ chức</span>!</h2>
                    <p class="text-slate-400 text-sm mt-1">Giao diện độc quyền dành riêng cho Đối tác và Tổ chức liên kết của CardWallet. Quản lý hệ thống con và doanh số hoa hồng của bạn.</p>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div class="bg-cardbg rounded-xl border border-borderbg p-5 flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-1">Cấp bậc hệ thống</p>
                            <h3 class="text-lg font-bold text-white">Đối tác liên kết (Nhóm 2)</h3>
                        </div>
                        <i class="fas fa-handshake text-teal-400 text-2xl"></i>
                    </div>
                    <div class="bg-cardbg rounded-xl border border-borderbg p-5 flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-1">Chiết khấu hệ thống</p>
                            <h3 class="text-lg font-bold text-emerald-400">Ưu đãi doanh số</h3>
                        </div>
                        <i class="fas fa-percent text-emerald-400 text-2xl"></i>
                    </div>
                    <div class="bg-cardbg rounded-xl border border-borderbg p-5 flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-1">Hạn mức chuyển khoản</p>
                            <h3 class="text-lg font-bold text-teal-400">Được phân quyền</h3>
                        </div>
                        <i class="fas fa-vault text-teal-400 text-2xl"></i>
                    </div>
                </div>

                <!-- Detailed Features Container -->
                <section class="bg-cardbg rounded-xl border border-borderbg overflow-hidden p-6">
                    <h3 class="font-bold text-white text-lg border-b border-borderbg pb-3">Tính năng đối tác được cấp phép</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-4">
                        <div class="rounded-lg bg-darkbg border border-borderbg p-4 hover:border-teal-500/50 transition-colors">
                            <h4 class="font-bold text-white flex items-center gap-2">
                                <i class="fas fa-link text-teal-400"></i> Quản lý mã REF & CTV
                            </h4>
                            <p class="text-xs text-slate-400 mt-2">Xem danh sách đăng ký qua link ref, cài đặt mã giới thiệu đặc quyền cho cộng tác viên trực thuộc.</p>
                        </div>
                        <div class="rounded-lg bg-darkbg border border-borderbg p-4 hover:border-teal-500/50 transition-colors">
                            <h4 class="font-bold text-white flex items-center gap-2">
                                <i class="fas fa-chart-line text-teal-400"></i> Báo cáo hoa hồng
                            </h4>
                            <p class="text-xs text-slate-400 mt-2">Theo dõi thống kê hoa hồng chiết khấu, doanh thu đổi thẻ của toàn bộ nhóm cộng tác viên con.</p>
                        </div>
                        <div class="rounded-lg bg-darkbg border border-borderbg p-4 hover:border-teal-500/50 transition-colors">
                            <h4 class="font-bold text-white flex items-center gap-2">
                                <i class="fas fa-coins text-teal-400"></i> Chuyển điểm nội bộ
                            </h4>
                            <p class="text-xs text-slate-400 mt-2">Cấp phát điểm/xu trực tiếp cho tài khoản con từ quỹ điểm đối tác mà không cần phê duyệt từ hệ thống.</p>
                        </div>
                        <div class="rounded-lg bg-darkbg border border-borderbg p-4 hover:border-teal-500/50 transition-colors">
                            <h4 class="font-bold text-white flex items-center gap-2">
                                <i class="fas fa-calendar-check text-teal-400"></i> Nhiệm vụ tổ chức
                            </h4>
                            <p class="text-xs text-slate-400 mt-2">Theo dõi và tạo lập chuỗi nhiệm vụ riêng biệt dành cho cộng tác viên của riêng tổ chức bạn.</p>
                        </div>
                        <div class="rounded-lg bg-darkbg border border-borderbg p-4 hover:border-teal-500/50 transition-colors">
                            <h4 class="font-bold text-white flex items-center gap-2">
                                <i class="fas fa-newspaper text-teal-400"></i> Bài đăng thương hiệu
                            </h4>
                            <p class="text-xs text-slate-400 mt-2">Đăng bài tin tức, chiến dịch tuyển dụng cộng tác viên để quảng bá thương hiệu tổ chức.</p>
                        </div>
                        <div class="rounded-lg bg-darkbg border border-borderbg p-4 opacity-50 border-dashed">
                            <h4 class="font-bold text-slate-500 flex items-center gap-2">
                                <i class="fas fa-ban"></i> Module Admin (Bị khóa)
                            </h4>
                            <p class="text-xs text-slate-500 mt-2">Các tính năng Admin cấp cao như cài đặt hệ thống, duyệt KYC và rút xu chỉ hiển thị trên app.mmohub.xyz.</p>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <!-- Script for validation, menu toggle, logout -->
    <script>
        document.addEventListener("DOMContentLoaded", async () => {
            const apiBase = '/api';

            // Sidebar toggling
            const sidebar = document.getElementById('partner-sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            const menuBtn = document.getElementById('menu-button');

            function toggleMenu() {
                sidebar.classList.toggle('hidden');
                sidebar.classList.toggle('flex');
                overlay.classList.toggle('hidden');
            }

            menuBtn?.addEventListener('click', toggleMenu);
            overlay?.addEventListener('click', toggleMenu);

            // Fetch Token helper
            function getToken() {
                const raw = localStorage.getItem('authData');
                if (raw) {
                    try {
                        const auth = JSON.parse(raw);
                        return auth.accessToken || auth.token || null;
                    } catch {
                        return null;
                    }
                }
                return null;
            }

            const token = getToken();
            if (!token) {
                redirectToLogin();
                return;
            }

            // Verify role via API call to /users/me
            try {
                const response = await fetch(`${apiBase}/users/me`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (!response.ok) {
                    redirectToLogin();
                    return;
                }

                const user = await response.json();
                if (user.role !== 'PartnerOrg') {
                    redirectToLogin();
                    return;
                }

                // Hydrate Profile Details
                const displayName = user.fullName || user.email || 'Đối tác';
                document.getElementById('partner-name').textContent = displayName;
                document.getElementById('welcome-name').textContent = displayName;
                document.getElementById('user-avatar').src = `https://ui-avatars.com/api/?name=${encodeURIComponent(displayName)}&background=0D8ABC&color=fff`;

            } catch (err) {
                console.error("Lỗi xác thực đối tác:", err);
                redirectToLogin();
            }

            // Logout action
            document.getElementById('logout-btn')?.addEventListener('click', async () => {
                const raw = localStorage.getItem('authData');
                if (raw) {
                    try {
                        const auth = JSON.parse(raw);
                        if (auth.refreshToken) {
                            await fetch(`${apiBase}/auth/logout`, {
                                method: 'POST',
                                headers: { 
                                    'Content-Type': 'application/json',
                                    'Authorization': `Bearer ${token}`
                                },
                                body: JSON.stringify({ refreshToken: auth.refreshToken })
                            });
                        }
                    } catch (e) {}
                }
                localStorage.removeItem('authData');
                redirectToLogin();
            });

            function redirectToLogin() {
                const host = window.location.host;
                let loginUrl = "";
                if (host.includes("localhost") || host.includes("127.0.0.1")) {
                    loginUrl = window.location.protocol + "//localhost:" + window.location.port + "/login";
                } else {
                    loginUrl = window.location.protocol + "//mmohub.xyz/login";
                }
                window.location.href = loginUrl;
            }
        });
    </script>
</body>
</html>
